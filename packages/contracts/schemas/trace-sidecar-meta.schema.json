{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/trace-sidecar-meta.schema.json",
  "title": "TraceSidecarMeta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "source_domain"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "trace_id": {
      "$ref": "#/$defs/id"
    },
    "source_domain": {
      "type": "string"
    },
    "source_uri": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "corpus_name": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "license": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "split": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "notes": {
      "oneOf": [
        { "type": "object" },
        { "type": "null" }
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._:-]+$"
    }
  }
}
